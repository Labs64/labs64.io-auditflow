APP_NAME := "auditflow"
REGISTRY  := "localhost:5005"

# List available recipes
default:
    @just --list

# Compile and package (skip tests)
build:
    mvn clean package -DskipTests

# Compile, run tests, and package
test:
    mvn clean verify

# validate the build-generated edge + domain Cedar policy sets against the
# shared commons schema
cedar-validate:
    @if [ -f target/generated-resources/auth-policy.cedar ]; then \
      for f in auth-policy.cedar auth-policy-domain.cedar; do \
        echo "validating $f"; \
        cedar validate \
          --schema ../../labs64.io-commons/auth-policy-cedar/schema.cedarschema \
          --schema-format cedar \
          --policies "target/generated-resources/$f"; \
      done; \
    else \
      echo "cedar not generated yet (run a maven build first)"; exit 1; \
    fi

# Build Docker image and push to local registry
docker: build
    docker build -t {{APP_NAME}}:latest .
    docker tag {{APP_NAME}}:latest {{REGISTRY}}/{{APP_NAME}}:latest
    docker push {{REGISTRY}}/{{APP_NAME}}:latest
    docker images | grep "{{APP_NAME}}"

# Run application locally with the 'local' Spring profile (requires docker compose --profile full up rabbitmq redis -d + transformer + sink running)
run: build
    mvn spring-boot:run -Dspring-boot.run.profiles=local

# Check for available Maven dependency, plugin, and property updates
check-updates:
    mvn versions:display-plugin-updates -Dmaven.version.ignore='(?i).*[.-]?(alpha|beta|RC|M)\d*'
    mvn versions:display-property-updates -Dmaven.version.ignore='(?i).*[.-]?(alpha|beta|RC|M)\d*'
    mvn versions:display-dependency-updates -DprocessDependencyManagement=false -Dmaven.version.ignore='(?i).*[.-]?(alpha|beta|RC|M)\d*'
    docker scout cves {{APP_NAME}}:latest
