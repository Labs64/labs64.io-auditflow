    {
      "id": 10,
      "title": "Heap used",
      "description": "JVM heap usage as a percentage of max (jvm_memory_used_bytes / jvm_memory_max_bytes, area=heap). Sustained >80 % triggers major GC pressure.",
      "type": "timeseries",
      "gridPos": {
        "h": 7,
        "w": 8,
        "x": 0,
        "y": 40
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(jvm_memory_used_bytes{job=\"auditflow-backend\",area=\"heap\"}) / sum(jvm_memory_max_bytes{job=\"auditflow-backend\",area=\"heap\"}) * 100",
          "legendFormat": "Heap %"
        }
      ],
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
