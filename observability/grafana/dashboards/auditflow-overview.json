{
  "uid": "auditflow-overview",
  "title": "AuditFlow Overview & Resilience",
  "tags": ["auditflow"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 5,
  "refresh": "10s",
  "time": {"from": "now-1h", "to": "now"},
  "panels": [

    {"id": 100, "type": "row", "title": "Event Flow",
     "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0}},

    {"id": 1, "title": "Events Published", "type": "stat",
     "description": "Total audit events published via POST /api/v1/audit/publish",
     "gridPos": {"h": 4, "w": 4, "x": 0, "y": 1},
     "datasource": {"type": "prometheus", "uid": "prometheus"},
     "targets": [{"refId": "A",
       "expr": "auditflow_rabbitmq_published_total{job=\"auditflow-backend\"}",
       "legendFormat": ""}],
     "options": {"reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
       "orientation": "horizontal", "textMode": "auto",
       "colorMode": "background", "graphMode": "area", "justifyMode": "center"},
     "fieldConfig": {"defaults": {"unit": "short", "decimals": 0,
       "color": {"mode": "fixed", "fixedColor": "blue"},
       "thresholds": {"mode": "absolute", "steps": [{"color": "blue", "value": null}]}}}},

    {"id": 2, "title": "Events Consumed", "type": "stat",
     "description": "Total events processed by the consumer",
     "gridPos": {"h": 4, "w": 4, "x": 4, "y": 1},
     "datasource": {"type": "prometheus", "uid": "prometheus"},
     "targets": [{"refId": "A",
       "expr": "auditflow_consumer_events_processed{job=\"auditflow-backend\"}",
       "legendFormat": ""}],
     "options": {"reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
       "orientation": "horizontal", "textMode": "auto",
       "colorMode": "background", "graphMode": "area", "justifyMode": "center"},
     "fieldConfig": {"defaults": {"unit": "short", "decimals": 0,
       "color": {"mode": "fixed", "fixedColor": "green"},
       "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}]}}}},

    {"id": 3, "title": "Pipelines Succeeded", "type": "stat",
     "gridPos": {"h": 4, "w": 4, "x": 8, "y": 1},
     "datasource": {"type": "prometheus", "uid": "prometheus"},
     "targets": [{"refId": "A",
       "expr": "auditflow_pipeline_outcomes_total{job=\"auditflow-backend\",outcome=\"SUCCESS\"}",
       "legendFormat": ""}],
     "options": {"reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
       "orientation": "horizontal", "textMode": "auto",
       "colorMode": "background", "graphMode": "area", "justifyMode": "center"},
     "fieldConfig": {"defaults": {"unit": "short", "decimals": 0,
       "color": {"mode": "fixed", "fixedColor": "green"},
       "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}]}}}},

    {"id": 4, "title": "Pipelines Failed", "type": "stat",
     "gridPos": {"h": 4, "w": 4, "x": 12, "y": 1},
     "datasource": {"type": "prometheus", "uid": "prometheus"},
     "targets": [{"refId": "A",
       "expr": "auditflow_pipeline_outcomes_total{job=\"auditflow-backend\",outcome=~\"POISON|RETRYABLE_FAILURE\"}",
       "legendFormat": ""}],
     "options": {"reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
       "orientation": "horizontal", "textMode": "auto",
       "colorMode": "background", "graphMode": "none", "justifyMode": "center"},
     "fieldConfig": {"defaults": {"unit": "short", "decimals": 0,
       "color": {"mode": "thresholds"},
       "thresholds": {"mode": "absolute", "steps": [
         {"color": "green", "value": null},
         {"color": "red", "value": 1}]}}}},

    {"id": 5, "title": "Deduplicated", "type": "stat",
     "gridPos": {"h": 4, "w": 4, "x": 16, "y": 1},
     "datasource": {"type": "prometheus", "uid": "prometheus"},
     "targets": [{"refId": "A",
       "expr": "auditflow_events_deduplicated_total{job=\"auditflow-backend\"}",
       "legendFormat": ""}],
     "options": {"reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
       "orientation": "horizontal", "textMode": "auto",
       "colorMode": "background", "graphMode": "none", "justifyMode": "center"},
     "fieldConfig": {"defaults": {"unit": "short", "decimals": 0,
       "color": {"mode": "thresholds"},
       "thresholds": {"mode": "absolute", "steps": [
         {"color": "green", "value": null},
         {"color": "yellow", "value": 1}]}}}},

    {"id": 6, "title": "Quarantined", "type": "stat",
     "gridPos": {"h": 4, "w": 4, "x": 20, "y": 1},
     "datasource": {"type": "prometheus", "uid": "prometheus"},
     "targets": [{"refId": "A",
       "expr": "auditflow_events_quarantined_total{job=\"auditflow-backend\"}",
       "legendFormat": ""}],
     "options": {"reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
       "orientation": "horizontal", "textMode": "auto",
       "colorMode": "background", "graphMode": "none", "justifyMode": "center"},
     "fieldConfig": {"defaults": {"unit": "short", "decimals": 0,
       "color": {"mode": "thresholds"},
       "thresholds": {"mode": "absolute", "steps": [
         {"color": "green", "value": null},
         {"color": "red", "value": 1}]}}}},

    {"id": 200, "type": "row", "title": "Pipeline Performance",
     "gridPos": {"h": 1, "w": 24, "x": 0, "y": 5}},

    {"id": 7, "title": "Pipeline Outcomes (rate/s)", "type": "timeseries",
     "gridPos": {"h": 8, "w": 8, "x": 0, "y": 6},
     "datasource": {"type": "prometheus", "uid": "prometheus"},
     "targets": [{"refId": "A",
       "expr": "sum(rate(auditflow_pipeline_outcomes_total{job=\"auditflow-backend\"}[$__rate_interval])) by (pipeline, outcome)",
       "legendFormat": "{{pipeline}} / {{outcome}}"}],
     "fieldConfig": {"defaults": {"unit": "reqps", "min": 0,
       "custom": {"lineWidth": 2, "fillOpacity": 10}}}},

    {"id": 8, "title": "Pipeline Duration P95 (ms)", "type": "timeseries",
     "gridPos": {"h": 8, "w": 8, "x": 8, "y": 6},
     "datasource": {"type": "prometheus", "uid": "prometheus"},
     "targets": [
       {"refId": "A",
        "expr": "histogram_quantile(0.95, sum(rate(auditflow_pipeline_duration_seconds_bucket{job=\"auditflow-backend\"}[$__rate_interval])) by (le, pipeline)) * 1000",
        "legendFormat": "P95 {{pipeline}}"},
       {"refId": "B",
        "expr": "histogram_quantile(0.50, sum(rate(auditflow_pipeline_duration_seconds_bucket{job=\"auditflow-backend\"}[$__rate_interval])) by (le, pipeline)) * 1000",
        "legendFormat": "P50 {{pipeline}}"}],
     "fieldConfig": {"defaults": {"unit": "ms", "min": 0,
       "custom": {"lineWidth": 2, "fillOpacity": 5}}}},

    {"id": 9, "title": "Consumer Inflight & HTTP Retries", "type": "timeseries",
     "gridPos": {"h": 8, "w": 8, "x": 16, "y": 6},
     "datasource": {"type": "prometheus", "uid": "prometheus"},
     "targets": [
       {"refId": "A",
        "expr": "auditflow_consumer_events_inflight{job=\"auditflow-backend\"}",
        "legendFormat": "Consumer Inflight"},
       {"refId": "B",
        "expr": "sum(rate(auditflow_http_retries_total{job=\"auditflow-backend\"}[$__rate_interval]))",
        "legendFormat": "HTTP Retries/s"}],
     "fieldConfig": {"defaults": {"unit": "short", "min": 0,
       "custom": {"lineWidth": 2, "fillOpacity": 10}}}},

    {"id": 300, "type": "row", "title": "Backend API (Inbound)",
     "gridPos": {"h": 1, "w": 24, "x": 0, "y": 14}},

    {"id": 10, "title": "Request Rate — excl. Actuator (req/s)", "type": "timeseries",
     "gridPos": {"h": 8, "w": 8, "x": 0, "y": 15},
     "datasource": {"type": "prometheus", "uid": "prometheus"},
     "targets": [{"refId": "A",
       "expr": "sum(rate(http_server_requests_seconds_count{job=\"auditflow-backend\",uri!~\"/actuator.*|/v3/api-docs.*\"}[$__rate_interval])) by (method, uri, status)",
       "legendFormat": "{{method}} {{uri}} {{status}}"}],
     "fieldConfig": {"defaults": {"unit": "reqps", "min": 0,
       "custom": {"lineWidth": 2, "fillOpacity": 10}}}},

    {"id": 11, "title": "Error Rate 5xx (req/s)", "type": "timeseries",
     "gridPos": {"h": 8, "w": 8, "x": 8, "y": 15},
     "datasource": {"type": "prometheus", "uid": "prometheus"},
     "targets": [{"refId": "A",
       "expr": "sum(rate(http_server_requests_seconds_count{job=\"auditflow-backend\",status=~\"5..\",uri!~\"/actuator.*\"}[$__rate_interval])) by (method, uri)",
       "legendFormat": "{{method}} {{uri}}"}],
     "fieldConfig": {"defaults": {"unit": "reqps", "min": 0,
       "custom": {"lineWidth": 2, "fillOpacity": 20},
       "color": {"mode": "fixed", "fixedColor": "red"}}}},

    {"id": 12, "title": "P95 Latency — Backend (ms)", "type": "timeseries",
     "gridPos": {"h": 8, "w": 8, "x": 16, "y": 15},
     "datasource": {"type": "prometheus", "uid": "prometheus"},
     "targets": [
       {"refId": "A",
        "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{job=\"auditflow-backend\",uri!~\"/actuator.*\"}[$__rate_interval])) by (le)) * 1000",
        "legendFormat": "P95"},
       {"refId": "B",
        "expr": "histogram_quantile(0.50, sum(rate(http_server_requests_seconds_bucket{job=\"auditflow-backend\",uri!~\"/actuator.*\"}[$__rate_interval])) by (le)) * 1000",
        "legendFormat": "P50"}],
     "fieldConfig": {"defaults": {"unit": "ms", "min": 0,
       "custom": {"lineWidth": 2, "fillOpacity": 5}}}},

    {"id": 400, "type": "row", "title": "Event Pipeline Flow — Backend → Transformer → Sink",
     "gridPos": {"h": 1, "w": 24, "x": 0, "y": 23}},

    {"id": 13, "title": "Backend → Transformer (req/s)", "type": "timeseries",
     "description": "Rate of HTTP calls from backend to transformer service",
     "gridPos": {"h": 8, "w": 8, "x": 0, "y": 24},
     "datasource": {"type": "prometheus", "uid": "prometheus"},
     "targets": [{"refId": "A",
       "expr": "sum(rate(auditflow_http_client_requests_seconds_count{service_name=\"auditflow-backend\",client_name=~\".*transformer.*\"}[$__rate_interval])) by (client_name)",
       "legendFormat": "{{client_name}}"}],
     "fieldConfig": {"defaults": {"unit": "reqps", "min": 0,
       "color": {"mode": "palette-classic"},
       "custom": {"lineWidth": 2, "fillOpacity": 10, "drawStyle": "line"}}}},

    {"id": 14, "title": "Backend → Sink (req/s)", "type": "timeseries",
     "description": "Rate of HTTP calls from backend to sink service",
     "gridPos": {"h": 8, "w": 8, "x": 8, "y": 24},
     "datasource": {"type": "prometheus", "uid": "prometheus"},
     "targets": [{"refId": "A",
       "expr": "sum(rate(auditflow_http_client_requests_seconds_count{service_name=\"auditflow-backend\",client_name=~\".*sink.*\"}[$__rate_interval])) by (client_name)",
       "legendFormat": "{{client_name}}"}],
     "fieldConfig": {"defaults": {"unit": "reqps", "min": 0,
       "color": {"mode": "palette-classic"},
       "custom": {"lineWidth": 2, "fillOpacity": 10, "drawStyle": "line"}}}},

    {"id": 15, "title": "End-to-End Pipeline Latency P95 (ms)", "type": "timeseries",
     "description": "P95 latency for the full pipeline: publish → consume → transform → sink",
     "gridPos": {"h": 8, "w": 8, "x": 16, "y": 24},
     "datasource": {"type": "prometheus", "uid": "prometheus"},
     "targets": [
       {"refId": "A",
        "expr": "histogram_quantile(0.95, sum(rate(auditflow_pipeline_duration_seconds_bucket{job=\"auditflow-backend\",outcome=\"SUCCESS\"}[$__rate_interval])) by (le, pipeline)) * 1000",
        "legendFormat": "P95 {{pipeline}}"},
       {"refId": "B",
        "expr": "histogram_quantile(0.50, sum(rate(auditflow_pipeline_duration_seconds_bucket{job=\"auditflow-backend\",outcome=\"SUCCESS\"}[$__rate_interval])) by (le, pipeline)) * 1000",
        "legendFormat": "P50 {{pipeline}}"},
       {"refId": "C",
        "expr": "histogram_quantile(0.99, sum(rate(auditflow_pipeline_duration_seconds_bucket{job=\"auditflow-backend\",outcome=\"SUCCESS\"}[$__rate_interval])) by (le, pipeline)) * 1000",
        "legendFormat": "P99 {{pipeline}}"}],
     "fieldConfig": {"defaults": {"unit": "ms", "min": 0,
       "custom": {"lineWidth": 2, "fillOpacity": 5}}}},

    {"id": 410, "type": "row", "title": "Python Services — Transformer & Sink",
     "gridPos": {"h": 1, "w": 24, "x": 0, "y": 32}},

    {"id": 16, "title": "Python Request Rate (req/s)", "type": "timeseries",
     "gridPos": {"h": 8, "w": 8, "x": 0, "y": 33},
     "datasource": {"type": "prometheus", "uid": "prometheus"},
     "targets": [{"refId": "A",
       "expr": "sum(rate(auditflow_http_server_duration_milliseconds_count{service_name=~\"auditflow-transformer|auditflow-sink\",http_target!~\"/health|/ready|/live|/info|/registry\"}[$__rate_interval])) by (service_name, http_target, http_method)",
       "legendFormat": "{{service_name}} {{http_method}} {{http_target}}"}],
     "fieldConfig": {"defaults": {"unit": "reqps", "min": 0,
       "custom": {"lineWidth": 2, "fillOpacity": 10}}}},

    {"id": 17, "title": "Python P95 Latency (ms)", "type": "timeseries",
     "gridPos": {"h": 8, "w": 8, "x": 8, "y": 33},
     "datasource": {"type": "prometheus", "uid": "prometheus"},
     "targets": [{"refId": "A",
       "expr": "histogram_quantile(0.95, sum(rate(auditflow_http_server_duration_milliseconds_bucket{service_name=~\"auditflow-transformer|auditflow-sink\",http_target!~\"/health|/ready|/live|/info|/registry\"}[$__rate_interval])) by (le, service_name, http_target))",
       "legendFormat": "P95 {{service_name}} {{http_target}}"}],
     "fieldConfig": {"defaults": {"unit": "ms", "min": 0,
       "custom": {"lineWidth": 2, "fillOpacity": 5}}}},

    {"id": 18, "title": "Outbound Calls — Backend → Python (req/s & P95 ms)", "type": "timeseries",
     "gridPos": {"h": 8, "w": 8, "x": 16, "y": 33},
     "datasource": {"type": "prometheus", "uid": "prometheus"},
     "targets": [
       {"refId": "A",
        "expr": "sum(rate(auditflow_http_client_requests_seconds_count{service_name=\"auditflow-backend\"}[$__rate_interval])) by (client_name, uri)",
        "legendFormat": "rate {{client_name}} {{uri}}"},
       {"refId": "B",
        "expr": "histogram_quantile(0.95, sum(rate(auditflow_http_client_requests_seconds_bucket{service_name=\"auditflow-backend\"}[$__rate_interval])) by (le, client_name)) * 1000",
        "legendFormat": "P95 {{client_name}}"}],
     "fieldConfig": {
       "defaults": {"unit": "short", "min": 0, "custom": {"lineWidth": 2, "fillOpacity": 5}},
       "overrides": [
         {"matcher": {"id": "byFrameRefID", "options": "B"},
          "properties": [{"id": "unit", "value": "ms"},
                         {"id": "custom.axisPlacement", "value": "right"}]}]}},

    {"id": 500, "type": "row", "title": "Resilience & Stability",
     "gridPos": {"h": 1, "w": 24, "x": 0, "y": 41}},

    {"id": 19, "title": "Circuit Breaker State", "type": "timeseries",
     "gridPos": {"h": 8, "w": 8, "x": 0, "y": 42},
     "datasource": {"type": "prometheus", "uid": "prometheus"},
     "targets": [{"refId": "A",
       "expr": "resilience4j_circuitbreaker_state{job=\"auditflow-backend\"} == 1",
       "legendFormat": "{{name}} — {{state}}"}],
     "fieldConfig": {"defaults": {"unit": "short", "min": 0, "max": 1,
       "custom": {"lineWidth": 0, "fillOpacity": 70, "spanNulls": false},
       "color": {"mode": "palette-classic"}}}},

    {"id": 20, "title": "Circuit Breaker Failure Rate (%)", "type": "timeseries",
     "gridPos": {"h": 8, "w": 8, "x": 8, "y": 42},
     "datasource": {"type": "prometheus", "uid": "prometheus"},
     "targets": [{"refId": "A",
       "expr": "resilience4j_circuitbreaker_failure_rate{job=\"auditflow-backend\"}",
       "legendFormat": "{{name}}"},
       {"refId": "B",
        "expr": "resilience4j_circuitbreaker_slow_call_rate{job=\"auditflow-backend\"}",
        "legendFormat": "slow {{name}}"}],
     "fieldConfig": {"defaults": {"unit": "percent", "min": 0, "max": 100,
       "custom": {"lineWidth": 2, "fillOpacity": 10},
       "thresholds": {"mode": "absolute",
         "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 30}, {"color": "red", "value": 50}]}}}},

    {"id": 21, "title": "CB Calls Blocked / Failed (req/s)", "type": "timeseries",
     "gridPos": {"h": 8, "w": 8, "x": 16, "y": 42},
     "datasource": {"type": "prometheus", "uid": "prometheus"},
     "targets": [
       {"refId": "A",
        "expr": "sum(rate(resilience4j_circuitbreaker_not_permitted_calls_total{job=\"auditflow-backend\"}[$__rate_interval])) by (name)",
        "legendFormat": "blocked {{name}}"},
       {"refId": "B",
        "expr": "sum(rate(resilience4j_circuitbreaker_calls_seconds_count{job=\"auditflow-backend\",kind=\"failed\"}[$__rate_interval])) by (name)",
        "legendFormat": "failed {{name}}"}],
     "fieldConfig": {"defaults": {"unit": "reqps", "min": 0,
       "custom": {"lineWidth": 2, "fillOpacity": 15}}}},

    {"id": 700, "type": "row", "title": "JVM Health (Backend)",
     "gridPos": {"h": 1, "w": 24, "x": 0, "y": 50}},

    {"id": 22, "title": "JVM Heap Memory Used", "type": "timeseries",
     "gridPos": {"h": 8, "w": 8, "x": 0, "y": 51},
     "datasource": {"type": "prometheus", "uid": "prometheus"},
     "targets": [
       {"refId": "A",
        "expr": "sum(jvm_memory_used_bytes{job=\"auditflow-backend\",area=\"heap\"}) by (id)",
        "legendFormat": "used {{id}}"},
       {"refId": "B",
        "expr": "sum(jvm_memory_max_bytes{job=\"auditflow-backend\",area=\"heap\"}) by (id)",
        "legendFormat": "max {{id}}"}],
     "fieldConfig": {"defaults": {"unit": "bytes", "min": 0,
       "custom": {"lineWidth": 2, "fillOpacity": 10}}}},

    {"id": 23, "title": "CPU Usage", "type": "timeseries",
     "gridPos": {"h": 8, "w": 8, "x": 8, "y": 51},
     "datasource": {"type": "prometheus", "uid": "prometheus"},
     "targets": [
       {"refId": "A",
        "expr": "process_cpu_usage{job=\"auditflow-backend\"}",
        "legendFormat": "Process CPU"},
       {"refId": "B",
        "expr": "system_cpu_usage{job=\"auditflow-backend\"}",
        "legendFormat": "System CPU"}],
     "fieldConfig": {"defaults": {"unit": "percentunit", "min": 0, "max": 1,
       "custom": {"lineWidth": 2, "fillOpacity": 10}}}},

    {"id": 24, "title": "JVM GC Pause P95 (ms)", "type": "timeseries",
     "gridPos": {"h": 8, "w": 8, "x": 16, "y": 51},
     "datasource": {"type": "prometheus", "uid": "prometheus"},
     "targets": [
       {"refId": "A",
        "expr": "histogram_quantile(0.95, sum(rate(jvm_gc_pause_seconds_bucket{job=\"auditflow-backend\"}[$__rate_interval])) by (le, gc, action)) * 1000",
        "legendFormat": "P95 {{gc}} {{action}}"},
       {"refId": "B",
        "expr": "jvm_threads_live_threads{job=\"auditflow-backend\"}",
        "legendFormat": "Threads (live)"}],
     "fieldConfig": {
       "defaults": {"unit": "ms", "min": 0, "custom": {"lineWidth": 2, "fillOpacity": 5}},
       "overrides": [
         {"matcher": {"id": "byFrameRefID", "options": "B"},
          "properties": [{"id": "unit", "value": "short"},
                         {"id": "custom.axisPlacement", "value": "right"}]}]}},

    {"id": 800, "type": "row", "title": "Telemetry — Traces & Logs",
     "gridPos": {"h": 1, "w": 24, "x": 0, "y": 59}},

    {"id": 25, "title": "Recent Traces", "type": "traces",
     "gridPos": {"h": 14, "w": 12, "x": 0, "y": 60},
     "datasource": {"type": "tempo", "uid": "tempo"},
     "targets": [{"refId": "A",
       "queryType": "traceql",
       "query": "{}",
       "limit": 20,
       "tableType": "traces"}],
     "options": {"dedupStrategy": "none", "sortBy": []}},

    {"id": 26, "title": "Log Stream — All Services", "type": "logs",
     "gridPos": {"h": 14, "w": 12, "x": 12, "y": 60},
     "datasource": {"type": "loki", "uid": "loki"},
     "targets": [{"refId": "A",
       "expr": "{service_name=~\"auditflow-backend|auditflow-transformer|auditflow-sink\"}",
       "queryType": "range"}],
     "options": {
       "showTime": true,
       "showLabels": true,
       "showCommonLabels": false,
       "wrapLogMessage": true,
       "sortOrder": "Descending",
       "enableLogDetails": true,
       "prettifyLogMessage": false,
       "dedupStrategy": "none"}}
  ]
}
