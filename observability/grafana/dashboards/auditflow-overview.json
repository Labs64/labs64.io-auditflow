    {
      "id": 300,
      "type": "row",
      "title": "Stage performance",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 25
      }
    },
    {
      "id": 7,
      "title": "Backend \u2014 publish latency",
      "description": "Spring Boot HTTP server latency for the audit publish endpoint (http_server_requests_seconds histogram). P95 and P50 in milliseconds. Excludes actuator and OpenAPI paths.",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 26
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by(le) (rate(http_server_requests_seconds_bucket{job=\"auditflow-backend\",uri!~\"/actuator.*|/v3.*|/swagger.*\"}[$__rate_interval]))) * 1000",
          "legendFormat": "P95"
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.50, sum by(le) (rate(http_server_requests_seconds_bucket{job=\"auditflow-backend\",uri!~\"/actuator.*|/v3.*|/swagger.*\"}[$__rate_interval]))) * 1000",
          "legendFormat": "P50"
        }
      ],
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "mean",
            "max"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "min": 0,
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 8
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "P95"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#e34948"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "P50"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#2a78d6"
                }
              }
            ]
          }
        ]
      }
    },
    {
      "id": 8,
      "title": "Transformer latency",
      "description": "FastAPI HTTP server latency for auditflow-transformer, via OTel Collector (auditflow namespace, resource_to_telemetry_conversion=true). Uses 'or' to cover both OTel HTTP semconv versions.",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 26
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "(histogram_quantile(0.95, sum by(le) (rate(auditflow_http_server_request_duration_seconds_bucket{service_name=\"auditflow-transformer\"}[$__rate_interval]))) * 1000)\nor\nhistogram_quantile(0.95, sum by(le) (rate(auditflow_http_server_duration_milliseconds_bucket{service_name=\"auditflow-transformer\"}[$__rate_interval])))",
          "legendFormat": "P95"
        },
        {
          "refId": "B",
          "expr": "(histogram_quantile(0.5, sum by(le) (rate(auditflow_http_server_request_duration_seconds_bucket{service_name=\"auditflow-transformer\"}[$__rate_interval]))) * 1000)\nor\nhistogram_quantile(0.5, sum by(le) (rate(auditflow_http_server_duration_milliseconds_bucket{service_name=\"auditflow-transformer\"}[$__rate_interval])))",
          "legendFormat": "P50"
        }
      ],
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
