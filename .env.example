# AuditFlow — Local environment variables
#
# Copy this file to .env and adjust values as needed.
# The .env file is NOT committed to source control.
#
#   cp .env.example .env

# RabbitMQ credentials used by both docker-compose and the Spring Boot app.
# Defaults to guest/guest which is fine for local development only.
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest
