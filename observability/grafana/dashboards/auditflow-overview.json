{
  "uid": "auditflow-overview",
  "title": "AuditFlow Overview & Resilience",
  "tags": [
    "auditflow"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 2,
  "refresh": "10s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "panels": [
    {
      "id": 100,
      "type": "row",
      "title": "Backend API Performance",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      }
    },
    {
      "id": 1,
      "title": "Request Rate (req/s) - Excl. Actuator",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 1
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(http_server_requests_seconds_count{job=\"auditflow-backend\",uri!~\"/actuator.*|/v3/api-docs.*\"}[1m])) by (method, uri, status)",
          "legendFormat": "{{method}} {{uri}} - {{status}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {},
          "unit": "reqps",
          "min": 0
        }
      }
    },
    {
      "id": 2,
      "title": "Error Rate (5xx req/s)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 1
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(http_server_requests_seconds_count{job=\"auditflow-backend\",status=~\"5..\",uri!~\"/actuator.*|/v3/api-docs.*\"}[1m])) by (method, uri)",
          "legendFormat": "{{method}} {{uri}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {},
          "unit": "reqps",
          "min": 0
        }
      }
    },
    {
      "id": 3,
      "title": "P95 Latency (ms)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 1
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{job=\"auditflow-backend\",uri!~\"/actuator.*\"}[1m])) by (le)) * 1000",
          "legendFormat": "P95 Latency"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {},
          "unit": "ms",
          "min": 0
        }
      }
    },
    {
      "id": 200,
      "type": "row",
      "title": "Resilience & Stability",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 9
      }
    },
    {
      "id": 4,
      "title": "Circuit Breakers (Open / Half-Open)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 10
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "resilience4j_circuitbreaker_state{state=~\"open|half_open\"} > 0",
          "legendFormat": "{{name}} - {{state}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {},
          "unit": "short",
          "min": 0
        }
      }
    },
    {
      "id": 5,
      "title": "Circuit Breaker Failed Calls (req/s)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 10
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(resilience4j_circuitbreaker_calls_total{kind=\"failed\"}[1m])) by (name)",
          "legendFormat": "{{name}} (failed)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {},
          "unit": "reqps",
          "min": 0
        }
      }
    },
    {
      "id": 6,
      "title": "Rate Limiter Available Permissions",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 10
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "resilience4j_ratelimiter_available_permissions",
          "legendFormat": "{{name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {},
          "unit": "short",
          "min": 0
        }
      }
    },
    {
      "id": 300,
      "type": "row",
      "title": "JVM Health (Backend)",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 18
      }
    },
    {
      "id": 7,
      "title": "JVM Memory Used",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 19
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(jvm_memory_used_bytes{area=\"heap\"}) by (id)",
          "legendFormat": "{{id}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {},
          "unit": "bytes",
          "min": 0
        }
      }
    },
    {
      "id": 8,
      "title": "JVM CPU Usage",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 19
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "process_cpu_usage{job=\"auditflow-backend\"}",
          "legendFormat": "CPU Usage"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {},
          "unit": "percentunit",
          "min": 0
        }
      },
      "max": 1
    },
    {
      "id": 400,
      "type": "row",
      "title": "Telemetry",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 27
      }
    },
    {
      "id": 9,
      "title": "Recent Traces",
      "type": "traces",
      "gridPos": {
        "h": 12,
        "w": 12,
        "x": 0,
        "y": 28
      },
      "datasource": {
        "type": "tempo",
        "uid": "tempo"
      },
      "targets": [
        {
          "queryType": "nativeSearch",
          "limit": 20,
          "refId": "A"
        }
      ]
    },
    {
      "id": 10,
      "title": "Log Stream",
      "type": "logs",
      "gridPos": {
        "h": 12,
        "w": 12,
        "x": 12,
        "y": 28
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "{job=~\"auditflow-backend|auditflow-transformer|auditflow-sink\"} | json | line_format \"{{.message}}\"",
          "queryType": "range"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": false,
        "sortOrder": "Descending",
        "wrapLogMessage": true,
        "enableLogDetails": true
      }
    }
  ]
}