    {
      "id": 200,
      "type": "row",
      "title": "Event flow",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 10
      }
    },
    {
      "id": 5,
      "title": "Submitted vs delivered vs failed",
      "description": "Blue = HTTP 2xx publishes arriving at the backend. Green = events successfully delivered through the full pipeline. Red = poison or retryable failures. A gap between blue and green that is not explained by 'Skipped' indicates queue build-up or pipeline inefficiency.",
      "type": "timeseries",
      "gridPos": {
        "h": 9,
        "w": 16,
        "x": 0,
        "y": 11
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(http_server_requests_seconds_count{job=\"auditflow-backend\",uri!~\"/actuator.*|/v3.*|/swagger.*\",status=~\"2..\"}[$__rate_interval]))",
          "legendFormat": "Submitted"
        },
        {
          "refId": "B",
          "expr": "sum(rate(auditflow_pipeline_outcomes_total{job=\"auditflow-backend\",outcome=\"SUCCESS\"}[$__rate_interval]))",
          "legendFormat": "Delivered"
        },
        {
          "refId": "C",
          "expr": "sum(rate(auditflow_pipeline_outcomes_total{job=\"auditflow-backend\",outcome=~\"POISON|RETRYABLE_FAILURE\"}[$__rate_interval]))",
          "legendFormat": "Failed"
        },
        {
          "refId": "D",
          "expr": "sum(rate(auditflow_pipeline_outcomes_total{job=\"auditflow-backend\",outcome=\"SKIPPED\"}[$__rate_interval]))",
          "legendFormat": "Skipped"
        }
      ],
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "mean",
            "lastNotNull",
            "max"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "min": 0,
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 8
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Submitted"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "blue"
                }
              },
              {
                "id": "custom.fillOpacity",
                "value": 20
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Delivered"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "green"
                }
              },
              {
                "id": "custom.fillOpacity",
                "value": 8
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Failed"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "red"
                }
              },
              {
                "id": "custom.fillOpacity",
                "value": 25
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Skipped"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "gray"
                }
              },
              {
                "id": "custom.fillOpacity",
                "value": 5
              }
            ]
          }
        ]
      }
    },
    {
      "id": 6,
      "title": "Queue depth over time",
      "description": "RabbitMQ messages_ready for the audit queue. A sustained upward trend means the consumer cannot keep pace with submission rate. Flat at zero is the expected steady-state.",
      "type": "timeseries",
      "gridPos": {
        "h": 9,
        "w": 8,
        "x": 16,
        "y": 11
      },
      "datasource": {
        "type": "prometheus",
