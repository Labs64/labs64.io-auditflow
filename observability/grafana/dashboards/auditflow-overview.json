{
  "uid": "auditflow-overview",
  "title": "AuditFlow \u2014 Overview",
  "description": "Focused operational view: submission rate, failure signal, queue depth, per-stage latency, and essential JVM health. Four rows, twelve panels.",
  "tags": [
    "auditflow"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "15s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0,211,255,1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "panels": [
    {
      "id": 100,
      "type": "row",
      "title": "Status",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      }
    },
    {
      "id": 1,
      "title": "Submit rate",
      "description": "Successful HTTP requests reaching the publish endpoint per second (http_server_requests_seconds_count, Spring Boot auto-metric).",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 1
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(http_server_requests_seconds_count{job=\"auditflow-backend\",uri!~\"/actuator.*|/v3.*|/swagger.*\",status=~\"2..\"}[$__rate_interval]))",
          "legendFormat": ""
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "decimals": 2,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "title": "Pipeline success",
      "description": "Fraction of pipeline executions that completed with outcome=SUCCESS. SLO: \u226599 % green, \u226595 % yellow, below red (auditflow_pipeline_outcomes_total).",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 1
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(auditflow_pipeline_outcomes_total{job=\"auditflow-backend\",outcome=\"SUCCESS\"}[$__rate_interval])) / clamp_min(sum(rate(auditflow_pipeline_outcomes_total{job=\"auditflow-backend\",outcome!=\"SKIPPED\"}[$__rate_interval])), 0.001) * 100",
          "legendFormat": ""
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 95
              },
              {
                "color": "green",
                "value": 99
              }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "title": "Queue depth",
      "description": "RabbitMQ messages waiting to be consumed (rabbitmq_queue_messages_ready \u2014 requires the RabbitMQ Prometheus plugin enabled on the broker, or Spring Boot actuator RabbitMQ metrics).",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 1
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "rabbitmq_queue_messages_ready{queue=\"labs64-audit-topic.labs64.io-auditflow\"}",
          "legendFormat": ""
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 500
              },
              {
                "color": "red",
                "value": 2000
              }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "Failure rate",
      "description": "Pipeline POISON + RETRYABLE_FAILURE events per second (auditflow_pipeline_outcomes_total). Any non-zero value warrants investigation.",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 1
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(auditflow_pipeline_outcomes_total{job=\"auditflow-backend\",outcome=~\"POISON|RETRYABLE_FAILURE\"}[$__rate_interval]))",
          "legendFormat": ""
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "decimals": 3,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 0.001
              }
            ]
          }
        }
      }
    },
    {
      "id": 200,
      "type": "row",
      "title": "Event flow",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 5
      }
    },
    {
      "id": 5,
      "title": "Submitted vs delivered vs failed",
      "description": "Blue = HTTP 2xx publishes arriving at the backend. Green = events successfully delivered through the full pipeline. Red = poison or retryable failures. A gap between blue and green that is not explained by 'Skipped' indicates queue build-up or pipeline inefficiency.",
      "type": "timeseries",
      "gridPos": {
        "h": 9,
        "w": 16,
        "x": 0,
        "y": 6
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(http_server_requests_seconds_count{job=\"auditflow-backend\",uri!~\"/actuator.*|/v3.*|/swagger.*\",status=~\"2..\"}[$__rate_interval]))",
          "legendFormat": "Submitted"
        },
        {
          "refId": "B",
          "expr": "sum(rate(auditflow_pipeline_outcomes_total{job=\"auditflow-backend\",outcome=\"SUCCESS\"}[$__rate_interval]))",
          "legendFormat": "Delivered"
        },
        {
          "refId": "C",
          "expr": "sum(rate(auditflow_pipeline_outcomes_total{job=\"auditflow-backend\",outcome=~\"POISON|RETRYABLE_FAILURE\"}[$__rate_interval]))",
          "legendFormat": "Failed"
        },
        {
          "refId": "D",
          "expr": "sum(rate(auditflow_pipeline_outcomes_total{job=\"auditflow-backend\",outcome=\"SKIPPED\"}[$__rate_interval]))",
          "legendFormat": "Skipped"
        }
      ],
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "mean",
            "lastNotNull",
            "max"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "min": 0,
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 8
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Submitted"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "blue"
                }
              },
              {
                "id": "custom.fillOpacity",
                "value": 20
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Delivered"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "green"
                }
              },
              {
                "id": "custom.fillOpacity",
                "value": 8
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Failed"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "red"
                }
              },
              {
                "id": "custom.fillOpacity",
                "value": 25
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Skipped"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "gray"
                }
              },
              {
                "id": "custom.fillOpacity",
                "value": 5
              }
            ]
          }
        ]
      }
    },
    {
      "id": 6,
      "title": "Queue depth over time",
      "description": "RabbitMQ messages_ready for the audit queue. A sustained upward trend means the consumer cannot keep pace with submission rate. Flat at zero is the expected steady-state.",
      "type": "timeseries",
      "gridPos": {
        "h": 9,
        "w": 8,
        "x": 16,
        "y": 6
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "rabbitmq_queue_messages_ready{queue=\"labs64-audit-topic.labs64.io-auditflow\"}",
          "legendFormat": "Pending"
        }
      ],
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "max"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 8
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Pending"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "orange"
                }
              },
              {
                "id": "custom.fillOpacity",
                "value": 30
              }
            ]
          }
        ]
      }
    },
